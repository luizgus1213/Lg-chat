    "pg": "latest",
    "pg-hstore": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "sequelize": "latest",
    "socket.io": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "sequelize-cli": "latest",
    "tsx": "latest",
